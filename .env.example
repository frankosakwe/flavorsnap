# FlavorSnap Environment Variables Example
# Copy this file to .env and update the values for your environment

# ================================
# Application Configuration
# ================================
NODE_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ================================
# Docker Configuration
# ================================
DOCKER_REGISTRY=
IMAGE_TAG=latest

# ================================
# Frontend Configuration
# ================================
# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_MODEL_ENDPOINT=/predict

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_DARK_MODE=true
ENABLE_CLASSIFICATION_HISTORY=true

# Model Configuration
MODEL_CONFIDENCE_THRESHOLD=0.6

# ================================
# Backend Configuration
# ================================
# Flask Settings
FLASK_ENV=development
FLASK_DEBUG=1
PYTHONPATH=/app

# Model Settings
MODEL_BATCH_SIZE=32
MAX_IMAGE_SIZE=224

# ================================
# Database Configuration
# ================================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flavorsnap
POSTGRES_USER=flavorsnap
POSTGRES_PASSWORD=flavorsnap_dev_password
POSTGRES_SSL_MODE=prefer

# Database Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
REDIS_DB=0

# ================================
# Production Environment Variables
# ================================
# Uncomment and update these for production deployment

# POSTGRES_HOST=postgres-service
# POSTGRES_PASSWORD=secure_production_password
# REDIS_HOST=redis-service
# REDIS_PASSWORD=secure_redis_password

# ================================
# Monitoring & Observability
# ================================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_RETENTION=200h
SCRAPE_INTERVAL=15s

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PASSWORD=grafana_admin_password

# ================================
# Performance & Scaling
# ================================
# Auto-scaling
AUTOSCALING_ENABLED=true
MIN_REPLICAS=1
MAX_REPLICAS=10
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80

# Caching
CACHING_ENABLED=true
CACHE_TTL=3600s
CACHE_MAX_SIZE=100MB

# ================================
# Security Configuration
# ================================
# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# API Keys (if using external services)
# OPENAI_API_KEY=your_openai_api_key
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ================================
# Development Specific
# ================================
# Development URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Testing
TEST_ENVIRONMENT=docker
CI=false

# ================================
# Production Specific
# ================================
# Uncomment for production
# NODE_ENV=production
# DEBUG=false
# LOG_LEVEL=INFO

# SSL/TLS
# SSL_CERT_PATH=/etc/ssl/certs/flavorsnap.crt
# SSL_KEY_PATH=/etc/ssl/private/flavorsnap.key

# ================================
# File Storage
# ================================
# Upload Settings
UPLOAD_FOLDER=/app/uploads
MAX_UPLOAD_SIZE=50MB
UPLOAD_CLEANUP_INTERVAL=24h

# Model Storage
MODEL_PATH=/app/model.pth
MODEL_BACKUP_INTERVAL=7d

# ================================
# Container Configuration
# ================================
# Resource Limits
FRONTEND_REPLICAS=1
BACKEND_REPLICAS=1

# Memory and CPU limits
FRONTEND_MEMORY_REQUEST=256Mi
FRONTEND_MEMORY_LIMIT=512Mi
FRONTEND_CPU_REQUEST=250m
FRONTEND_CPU_LIMIT=500m

BACKEND_MEMORY_REQUEST=1Gi
BACKEND_MEMORY_LIMIT=2Gi
BACKEND_CPU_REQUEST=500m
BACKEND_CPU_LIMIT=1000m

# ================================
# Logging Configuration
# ================================
# Container Logs
CONTAINER_MAX_LOG_SIZE=100m
CONTAINER_MAX_LOG_FILES=5

# Application Logs
APP_LOG_PATH=/app/logs
APP_LOG_ROTATION=daily
APP_LOG_RETENTION=30d

# ================================
# External Services
# ================================
# Email Service (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Cloud Storage (for file backups)
# AWS_S3_BUCKET=flavorsnap-backups
# AWS_REGION=us-east-1

# CDN (for static assets)
# CDN_URL=https://cdn.flavorsnap.com

# ================================
# Feature Flags
# ================================
# Enable/disable features
ENABLE_SOCIAL_SHARING=true
ENABLE_ANALYTICS_DASHBOARD=true
ENABLE_BATCH_PROCESSING=true
ENABLE_XAI_EXPLANATIONS=true
ENABLE_AB_TESTING=false

# ================================
# Health Check Configuration
# ================================
# Health check intervals
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=30s

# ================================
# Rate Limiting
# ================================
# API Rate Limits
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Upload Rate Limits
UPLOAD_RATE_LIMIT_PER_MINUTE=10
UPLOAD_RATE_LIMIT_BURST=3
